{
  "name": "moonsmp-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/gen-sprites.mjs && node scripts/set-db.mjs postgres && prisma generate && next build",
    "gen:sprites": "node scripts/gen-sprites.mjs",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:local": "node scripts/set-db.mjs sqlite && prisma db push && prisma generate && tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^16.12.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
